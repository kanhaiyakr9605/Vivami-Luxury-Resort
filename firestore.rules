rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && 
               data.email is string && 
               data.email.size() < 100 &&
               data.role in ['guest', 'admin', 'staff'] &&
               data.keys().hasAll(['uid', 'email', 'role']);
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'guest';
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role;
    }

    // 2. Service Requests
    match /serviceRequests/{requestId} {
      function isValidRequest(data) {
        return data.guestId is string &&
               data.type in ['taxi', 'waiter', 'cleaning', 'maintenance', 'concierge'] &&
               data.status in ['pending', 'in-progress', 'completed', 'cancelled'] &&
               data.guestId == request.auth.uid;
      }

      allow create: if isSignedIn() && isValidRequest(incoming());
      allow read: if isSignedIn() && (resource == null || resource.data.guestId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.guestId == request.auth.uid;
    }

    // 3. Bookings
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && resource.data.guestId == request.auth.uid;
    }

    // 4. Menu Items
    match /menuItems/{itemId} {
      allow read: if true; // Publicly viewable
    }
  }
}
